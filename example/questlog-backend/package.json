{
  "name": "questlog-backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check . --write --unsafe",
    "db-dev-up": "docker-compose -f docker/dev/docker-compose.yml up",
    "db-dev-kill": "rm -rf docker/dev/postgresql-data",
    "db-test-up": "docker compose -f docker/test/docker-compose.yml up",
    "db-test-kill": "rm -rf docker/test/postgresql-data"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "hono": "^4.7.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
