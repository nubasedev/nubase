{
  "name": "@nubase/example-app-schema",
  "version": "0.1.0",
  "description": "Schema for the Example App",
  "sideEffects": ["**/*.css"],
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/js/index.d.ts",
      "import": "./dist/js/index.mjs",
      "require": "./dist/js/index.js"
    }
  },
  "license": "MIT",
  "scripts": {
    "build:ts": "tsup",
    "build:storybook": "storybook build",
    "build": "npm run build:ts",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "watch:ts": "tsup --watch",
    "dev": "concurrently \"npm:watch:ts\""
  },
  "peerDependencies": {
    "react": "^19"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@storybook/addon-docs": "^9.0.10",
    "@storybook/addon-onboarding": "^9.0.10",
    "@storybook/react-vite": "^9.0.10",
    "@tailwindcss/cli": "^4.0.12",
    "@tailwindcss/postcss": "^4.0.12",
    "@types/react": "^19.0.12",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "storybook": "^9.0.10",
    "tailwindcss": "^4.1.3",
    "tsup": "^8.0.0",
    "typescript": "5.8.2",
    "concurrently": "^9.2.0"
  },
  "dependencies": {
    "@repo/core": "file:../core",
    "@tailwindcss/cli": "^4.1.3",
    "@tailwindcss/postcss": "^4.1.3",
    "@tanstack/react-form": "^1.12.3",
    "@tanstack/react-router": "^1.121.2",
    "@tanstack/react-router-devtools": "^1.121.12",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "postcss": "^8.5.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.0.12"
  }
}
