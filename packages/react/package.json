{
  "name": "@nubase/react",
  "version": "0.1.0",
  "description": "React components and utilities for nubase",
  "keywords": ["react", "components", "forms", "table", "ui"],
  "sideEffects": ["**/*.css"],
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "scripts": {
    "build:ts": "tsup",
    "build:css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css",
    "build:storybook": "storybook build",
    "build": "npm run build:ts && npm run build:css && npm run build:storybook",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check . --write --unsafe",
    "prepublishOnly": "npm run build",
    "watch:ts": "tsup --watch",
    "watch:css": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --watch",
    "storybook": "storybook dev -p 6006 --no-open",
    "dev": "concurrently \"npm:watch:ts\" \"npm:watch:css\" \"npm:storybook\""
  },
  "peerDependencies": {
    "react": "^19"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@storybook/addon-docs": "^9.0.10",
    "@storybook/addon-onboarding": "^9.0.10",
    "@storybook/addon-themes": "^9.0.17",
    "@storybook/react-vite": "^9.0.10",
    "@tailwindcss/cli": "^4.0.12",
    "@tailwindcss/postcss": "^4.0.12",
    "@types/react": "^19.0.12",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.0",
    "postcss": "^8.5.3",
    "storybook": "^9.0.10",
    "tailwindcss": "^4.1.3",
    "tsup": "^8.0.0",
    "typescript": "5.8.2",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@nubase/core": "*",
    "@tabler/icons-react": "^3.34.0",
    "@tailwindcss/cli": "^4.1.3",
    "@tailwindcss/postcss": "^4.1.3",
    "@tanstack/react-form": "^1.12.3",
    "@tanstack/react-router": "^1.121.2",
    "@tanstack/react-router-devtools": "^1.121.12",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "postcss": "^8.5.3",
    "react-hotkeys-hook": "^5.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.0.12"
  }
}
