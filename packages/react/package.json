{
  "name": "@nubase/react",
  "version": "0.1.0",
  "description": "React components and utilities for nubase",
  "keywords": ["react", "components", "forms", "table", "ui"],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./theme.css": "./dist/theme.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup && tailwindcss -i ./src/styles.css -o ./dist/styles.css && cp ./src/theme/theme.css ./dist/theme.css",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@storybook/addon-docs": "^9.0.10",
    "@storybook/addon-onboarding": "^9.0.10",
    "@storybook/react-vite": "^9.0.10",
    "@tailwindcss/cli": "^4.0.12",
    "@tailwindcss/postcss": "^4.0.12",
    "@types/react": "^19.0.12",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "storybook": "^9.0.10",
    "tailwindcss": "^4.1.3",
    "tsup": "^8.0.0",
    "typescript": "5.8.2"
  },
  "dependencies": {
    "@nubase/core": "file:../core",
    "@tailwindcss/cli": "^4.1.3",
    "@tailwindcss/postcss": "^4.1.3",
    "@tanstack/react-form": "^1.12.3",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1",
    "class-variance-authority": "^0.7.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.12",
    "@repo/core": "*"
  }
}
