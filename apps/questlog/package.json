{
  "name": "questlog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && vite build --mode server",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.backend.json && tsc --noEmit -p tsconfig.frontend.json",
    "lint": "biome check .",
    "lint:fix": "biome check . --write --unsafe",
    "test": "vitest run",
    "test:unit": "vitest run --exclude='**/*.integration.test.ts'",
    "test:integration": "vitest run '**/*.integration.test.ts'",
    "test:watch": "vitest",
    "dev:test": "NODE_ENV=test vite --mode test --port 4000",
    "db:up": "docker compose -p nubase-dev -f docker/dev/docker-compose.yml up -d",
    "db:down": "docker compose -p nubase-dev -f docker/dev/docker-compose.yml down",
    "db:kill": "docker compose -p nubase-dev -f docker/dev/docker-compose.yml down -v && rm -rf docker/dev/postgresql-data",
    "db:seed": "NODE_ENV=development tsx src/backend/db/seed.ts",
    "db:reset": "npm run db:kill && npm run db:schema-sync && npm run db:up && sleep 5 && npm run db:seed",
    "db:schema-sync": "cp db/schema.sql docker/dev/postgresql-init/dump.sql && cp db/schema.sql docker/test/postgresql-init/dump.sql",
    "db:test:up": "docker compose -p nubase-test -f docker/test/docker-compose.yml up -d",
    "db:test:down": "docker compose -p nubase-test -f docker/test/docker-compose.yml down",
    "db:test:kill": "docker compose -p nubase-test -f docker/test/docker-compose.yml down -v && rm -rf docker/test/postgresql-data",
    "db:test:reset": "npm run db:test:kill && npm run db:schema-sync && npm run db:test:up",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@hono/node-server": "^1.19.11",
    "@nubase/backend": "*",
    "@nubase/core": "*",
    "@nubase/frontend": "*",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.166.6",
    "@tanstack/react-router-devtools": "^1.166.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "hono": "^4.12.6",
    "kysely": "^0.27.6",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.539.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.5.0",
    "@hono/vite-dev-server": "^0.19.0",
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.30",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
