{
  "name": "with-tailwind",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:docs": "cd apps/docs && npm run build",
    "build:storybook": "cd packages/frontend && npm run build:storybook",
    "dev": "npm run db:up && turbo run dev --filter=!starter",
    "kill": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true",
    "dev:e2e": "turbo run dev dev:e2e",
    "dev:test": "turbo run dev:test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "check-types": "turbo run check-types",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write",
    "build:core": "cd packages/core && npm run build",
    "build:frontend": "cd packages/frontend && npm run build",
    "build:backend": "cd packages/backend && npm run build",
    "start": "cd apps/questlog && npm run start",
    "build:questlog": "cd apps/questlog && npm run build",
    "build:frontend:storybook": "cd packages/frontend && npm run build:storybook",
    "db:questlog": "./scripts/db-switch.sh questlog",
    "db:starter": "./scripts/db-switch.sh starter",
    "db:stop": "./scripts/db-switch.sh stop",
    "db:up": "npm run db:questlog",
    "db:down": "npm run db:stop",
    "db:seed": "cd apps/questlog && npm run db:seed",
    "db:seed:prod": "cd apps/questlog && npm run db:seed:prod",
    "db:reset": "cd apps/questlog && npm run db:reset",
    "db:reset:prod": "npm run cli -- db reset --env prod --force --yes && npm run db:seed:prod",
    "e2e": "turbo run e2e",
    "e2e:ui": "cd apps/questlog && npm run e2e:ui",
    "e2e:headed": "cd apps/questlog && npm run e2e:headed",
    "e2e:install": "cd apps/questlog && npm run e2e:install",
    "bump": "./scripts/bump-versions.sh",
    "publish": "./scripts/publish.sh",
    "starter:create": "./scripts/create-starter-example.sh",
    "starter:dev": "./scripts/dev-starter-example.sh",
    "starter:test": "./scripts/test-starter-example.sh",
    "starter:create-and-test": "npm run starter:create && npm run starter:test",
    "cli": "npm run -w @nubase/cli build && cd apps/questlog && node ../../packages/cli/dist/cli.js",
    "cli:envs": "npm run cli -- envs",
    "cli:db:diff": "npm run cli -- db diff",
    "cli:db:pull": "npm run cli -- db pull",
    "cli:db:push": "npm run cli -- db push",
    "cli:db:reset": "npm run cli -- db reset",
    "cli:init": "npm run cli -- init",
    "cli:db:codegen": "npm run cli -- db codegen"
  },
  "optionalDependencies": {
    "@parcel/watcher-linux-x64-glibc": "^2.5.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "turbo": "^2.8.15",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=10.9.2"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@rolldown/pluginutils": "1.0.0-rc.17"
  }
}
